# ── Mode ──────────────────────────────────────────────
MODE=paper                     # paper | live
LOG_LEVEL=INFO

# ── Polymarket ────────────────────────────────────────
POLYMARKET_SIGNING_KEY=your_hex_private_key_here
POLYMARKET_PROXY_URL=           # optional HTTP proxy for latency tuning

# ── Kalshi Demo ───────────────────────────────────────
KALSHI_DEMO_API_URL=https://demo-api.kalshi.com
KALSHI_DEMO_KEY_ID=your_demo_key_id
KALSHI_DEMO_PK_PATH=./keys/kalshi_demo.pem

# ── Kalshi Production ─────────────────────────────────
KALSHI_API_URL=https://api.elections.kalshi.com
KALSHI_KEY_ID=your_production_key_id
KALSHI_PK_PATH=./keys/kalshi_production.pem

# ── Coinbase ─────────────────────────────────────────
# API key/secret only needed for authenticated endpoints
COINBASE_API_KEY=
COINBASE_SECRET_B64=

# ── Execution ─────────────────────────────────────────
EXECUTION_VENUE=polymarket      # polymarket | kalshi | coinbase
SLIPPAGE_TOLERANCE_BPS=20

# ── Risk ──────────────────────────────────────────────
MAX_DAILY_LOSS_USD=100.0
MAX_TRADES_PER_MINUTE=60
